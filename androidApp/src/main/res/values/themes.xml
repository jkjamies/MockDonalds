<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MockDonalds" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!--
      Splash screen theme using the AndroidX SplashScreen compat library.
      Per https://developer.android.com/develop/ui/views/launch/splash-screen:
      - windowSplashScreenBackground: single color background
      - windowSplashScreenAnimatedIcon: AVD with M arches drawing animation
      - windowSplashScreenAnimationDuration: duration for the icon animation
      - postSplashScreenTheme: theme applied after splash dismisses
    -->
    <style name="Theme.MockDonalds.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/deep_obsidian</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo_animated</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.MockDonalds</item>
    </style>

</resources>
